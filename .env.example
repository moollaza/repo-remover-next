# Optional: Add your GitHub Personal Access Token for development convenience
# DEVELOPMENT ONLY - This avoids having to re-enter your token every time
# WARNING: Only use in local development, never commit real tokens to git
# Create token at: https://github.com/settings/tokens
# Required scopes: 'repo' (for repository management)
NEXT_PUBLIC_GITHUB_DEV_TOKEN=your_github_token_here

# Optional: Production monitoring (only needed if deploying your own instance)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# NEXT_PUBLIC_FATHOM_SITE_ID=your_fathom_site_id