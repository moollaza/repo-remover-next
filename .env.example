# Environment Configuration for Repo Remover
# Copy this file to .env.local and fill in your values

# ================================
# Development Environment
# ================================

# Next.js Environment
NODE_ENV=development

# ================================
# Production Monitoring (Optional)
# ================================

# Sentry.io Error Tracking
# Sign up at https://sentry.io and create a new Next.js project
# Only used in production for privacy compliance
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456
NEXT_PUBLIC_SENTRY_ORG=your-org
NEXT_PUBLIC_SENTRY_PROJECT=your-project

# Fathom Analytics (Privacy-first usage analytics)
# Sign up at https://usefathom.com and create a new site
# Only active in production with domain filtering
NEXT_PUBLIC_FATHOM_SITE_ID=ABCDEFGH

# Fathom Goal IDs for event tracking (optional)
NEXT_PUBLIC_FATHOM_TOKEN_VALID=GOAL123
NEXT_PUBLIC_FATHOM_REPOS_ARCHIVED=GOAL456
NEXT_PUBLIC_FATHOM_REPOS_DELETED=GOAL789
NEXT_PUBLIC_FATHOM_DASHBOARD_VIEW=GOAL012

# ================================
# GitHub Integration
# ================================

# No environment variables needed for GitHub integration!
# 
# This app uses a zero-knowledge architecture where users provide
# their own GitHub Personal Access Token (PAT) in the browser.
# The token is stored temporarily in sessionStorage and never
# sent to any backend servers.
#
# Users need to create a PAT at: https://github.com/settings/tokens
# Required scopes: 'repo' (for repository management)
#
# For security, tokens are:
# - Only stored in sessionStorage (cleared on tab close)
# - Sanitized from error logs and monitoring
# - Never transmitted to external services
# - Can be cleared by users at any time

# ================================
# Development Notes
# ================================

# Local Development:
# - No authentication setup required
# - Use npm run dev to start development server
# - Mock Service Worker handles API responses in development
# - Fathom and Sentry are disabled in development mode

# Production Deployment:
# - Set NODE_ENV=production
# - Configure monitoring services (optional but recommended)
# - Ensure HTTPS is enabled for security headers
# - Domain restrictions are automatically applied