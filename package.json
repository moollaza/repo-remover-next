{
  "name": "repo-remover",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test --max-failures=1 --retries=0 --reporter=line",
    "test:e2e:debug": "playwright test --headed --max-failures=1 --retries=0 --timeout=0",
    "test:e2e:headed": "playwright test --headed --max-failures=1",
    "test:e2e:ui": "playwright test --ui",
    "debug:e2e": "playwright test --debug",
    "test:all": "npm run test:unit && npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "sb": "npm run storybook",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
