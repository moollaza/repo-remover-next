{
  "name": "repo-remover",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:cf": "bun run build && wrangler dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test --max-failures=1 --retries=0 --reporter=line",
    "test:e2e:debug": "playwright test --headed --max-failures=1 --retries=0 --timeout=0",
    "test:e2e:headed": "playwright test --headed --max-failures=1",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test:unit && bun run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@sentry/react": "^10.43.0",
    "@typescript-eslint/parser": "^8.57.0",
    "class-variance-authority": "^0.7.1",
    "fathom-client": "^3.7.2",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@heroui/theme": "^2.4.26",
    "@octokit/core": "^7.0.6",
    "@octokit/graphql": "^8.1.1",
    "@octokit/graphql-schema": "^15.26.1",
    "@octokit/plugin-paginate-graphql": "^6.0.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/testing-library__user-event": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.11",
    "next-themes": "^0.4.6",
    "prettier": "3.8.1",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  }
}
