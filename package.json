{
  "name": "repo-remover",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:cf": "bun run build && wrangler dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test --max-failures=1 --retries=0 --reporter=line",
    "test:e2e:debug": "playwright test --headed --max-failures=1 --retries=0 --timeout=0",
    "test:e2e:headed": "playwright test --headed --max-failures=1",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test:unit && bun run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.1",
    "@fortawesome/free-brands-svg-icons": "^6.7.1",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@sentry/react": "^10.43.0",
    "fathom-client": "^3.7.2",
    "react": "^18",
    "react-dom": "^19",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@heroicons/react": "^2.1.5",
    "@heroui/react": "^2.8.10",
    "@heroui/system": "^2.4.28",
    "@heroui/theme": "^2.4.26",
    "@octokit/core": "^6.1.2",
    "@octokit/graphql": "^8.1.1",
    "@octokit/graphql-schema": "^15.25.0",
    "@octokit/plugin-paginate-graphql": "^5.2.4",
    "@octokit/plugin-throttling": "^9.4.0",
    "@octokit/rest": "^21.0.2",
    "@playwright/test": "^1.50.1",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-onboarding": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^10.2.19",
    "@storybook/test": "^8.6.12",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/testing-library__user-event": "^4.1.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chromatic": "^11.28.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-perfectionist": "^4.2.0",
    "eslint-plugin-storybook": "^0.12.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "msw": "^2.7.3",
    "msw-storybook-addon": "^2.0.4",
    "next-themes": "^0.4.3",
    "prettier": "3.3.3",
    "storybook": "^8.6.12",
    "swr": "^2.2.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  }
}
